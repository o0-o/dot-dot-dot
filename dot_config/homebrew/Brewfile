# Minimal terminal-environment dependencies — only what the managed dotfiles
# actually invoke. Deliberately NOT a machine manifest: per-machine software
# is installed and tracked outside chezmoi.
#
# NOTE: starship is intentionally absent — it installs to ~/.local/bin via its
# own installer, not Homebrew.

# Manage your dotfiles across multiple diverse machines, securely
brew "chezmoi"
# Load/unload environment variables based on $PWD
brew "direnv"
# Git extension for versioning large files — the managed git config sets
# filter "lfs" required = true, so git hard-fails on LFS repos without it
brew "git-lfs"
# GNU Privacy Guard (OpenPGP) — chezmoi encryption; gpg-agent.conf is managed
brew "gnupg"
# Ambitious Vim-fork focused on extensibility and agility ($EDITOR)
brew "neovim"
# Pinentry for GPG on Mac — hard-pathed in the managed gpg-agent.conf
brew "pinentry-mac"
# Terminal multiplexer
brew "tmux"
# Extremely fast Python package installer and resolver, written in Rust
brew "uv"
# MesloLGSDZ Nerd Font — kitty's configured font_family
cask "font-meslo-lg-nerd-font"
# GPU-based terminal emulator
cask "kitty"
