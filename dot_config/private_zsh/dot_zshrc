# ZSHRC

## Shared POSIX rc fragments (aliases usable by bash too)
for rc in "${XDG_CONFIG_HOME:-$HOME/.config}/sh/rc.d/"*.sh; do
  source "${rc}" ||
  printf 'ZSHRC: An error occured in %s\n' "${rc##*/}" >&2
done
unset rc

## History
HISTFILE="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/zsh_history"
[ -d "${HISTFILE%/*}" ] || install -m '700' -d "${HISTFILE%/*}"
export HISTFILE
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY

# up/down arrows prefix-search history (type a prefix, then arrow);
# Esc-k/j in vi command mode walks the full history unfiltered
autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey '^[OA' up-line-or-beginning-search
bindkey '^[OB' down-line-or-beginning-search
bindkey '^[[A' up-line-or-beginning-search
bindkey '^[[B' down-line-or-beginning-search

## Vi mode (replaces the omz vi-mode plugin)
bindkey -v
KEYTIMEOUT=1
bindkey '^?' backward-delete-char
bindkey '^R' history-incremental-search-backward

## Aliases (zsh-only; shared ones live in sh/rc.d)
if command -v ccat >/dev/null 2>&1; then
  alias cat="ccat --bg='dark' --color='auto'"
fi
if infocmp tmux-256color >/dev/null 2>&1; then
  alias tmux='TERM=tmux-256color tmux'
elif infocmp screen-256color >/dev/null 2>&1; then
  alias tmux='TERM=screen-256color tmux'
fi
if ls --color=auto . >/dev/null 2>&1; then
  alias ls='ls --color=auto'
else
  alias ls='ls -G'
fi

## direnv
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

## Claude Code
# clicks land on permission-prompt options as often as intended; scroll still works
export CLAUDE_CODE_DISABLE_MOUSE_CLICKS=1

## Completion — single compinit, dump in cache
if [ -n "${HOMEBREW_PREFIX-}" ] &&
   [ -d "${HOMEBREW_PREFIX}/share/zsh/site-functions" ]; then
  fpath+=("${HOMEBREW_PREFIX}/share/zsh/site-functions")
fi
autoload -Uz compinit
zcompdump="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump"
[ -d "${zcompdump%/*}" ] || install -m '700' -d "${zcompdump%/*}"
# root inherits our HOME/ZDOTDIR under `sudo -s` and flags our uid-owned fpath
# dirs as insecure; -u uses them without the check only there, where passwordless
# sudo already collapses the user→root boundary it guards. Our own shell keeps it.
if [ "$EUID" -eq 0 ]; then
  compinit -u -d "${zcompdump}"
else
  compinit -d "${zcompdump}"
fi
unset zcompdump
# case- and hyphen-insensitive matching, menu selection
zstyle ':completion:*' matcher-list 'm:{a-zA-Z-_}={A-Za-z_-}'
zstyle ':completion:*' menu select

## Tmux autostart (kitty windows only)
tmux-autostart() {
  [ "${TERM}" = 'xterm-kitty' ]       || return 0  # only from kitty
  [ "${UID}" != '0' ]                 || return 0  # not for root
  [ "${EUID}" != '0' ]                || return 0
  [ -z "${TMUX}" ]                    || return 0  # not inside tmux
  [ -z "${default_tmux_session}" ]    || return 0  # only once per shell
  [ -z "${INSIDE_EMACS}${EMACS}" ]    || return 0  # not inside emacs
  [ -z "${VIM}" ]                     || return 0  # not inside vim

  # use uid as default session
  export default_tmux_session="${UID:-0}"

  local plugins="${XDG_CONFIG_HOME:-$HOME/.config}/tmux/plugins"

  # if no plugins are installed, install them before starting the session
  if [ "$(ls -d "${plugins}/"* 2>/dev/null | wc -l)" -le 1 ]; then
    "${plugins}/tpm/bin/install_plugins"
  fi

  # if the session doesn't exist, daemonize it
  tmux ls -F '#S' 2>/dev/null | grep -q "^${default_tmux_session}" ||
  tmux new-session -s "${default_tmux_session}" -d &>/dev/null

  # clean up orphaned sessions
  tmux ls -F '#S#{?session_attached,attached,}' |
  grep -E "^${default_tmux_session}-[0-9]"      |
  grep -v 'attached$'                           |
  while read -r session; do
    tmux kill-session -t "${session}"
  done

  # create a new window if other sessions are attached,
  # otherwise attach to the existing window
  if tmux ls -F '#S#{?session_attached,attached,}' |
     grep -Eq "^${default_tmux_session}(-[0-9]+)?attached"; then
    tmux new-session -t "${default_tmux_session}" \; new-window
  else
    tmux attach -t "${default_tmux_session}"
  fi

  # install/update plugins in background
  ("${plugins}/tpm/bin/install_plugins"      &>/dev/null &)
  ("${plugins}/tpm/bin/update_plugins" 'all' &>/dev/null &)
}
tmux-autostart

## Prompt and plugins — only inside tmux
if [ -n "${TMUX-}" ]; then
  fsh="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/plugins/fast-syntax-highlighting"
  [ -r "${fsh}/fast-syntax-highlighting.plugin.zsh" ] &&
  source "${fsh}/fast-syntax-highlighting.plugin.zsh"
  unset fsh

  if command -v starship >/dev/null 2>&1; then
    # ascii prompt when the locale can't do unicode, or on demand
    # (PROMPT_ASCII=1) for terminals without the fancy glyphs
    if [ -n "${PROMPT_ASCII-}" ]; then
      export STARSHIP_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/starship-ascii.toml"
    else
      case "${LC_ALL:-${LC_CTYPE:-${LANG:-}}}" in
        (*[Uu][Tt][Ff]-8*|*[Uu][Tt][Ff]8*) ;;
        (*)
          export STARSHIP_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/starship-ascii.toml"
        ;;
      esac
    fi

    # context tag: root or remote session, static per shell (unset first
    # so nested shells don't inherit a stale state)
    unset PROMPT_CTX_ROOT PROMPT_CTX_REMOTE
    if [ "${EUID}" = '0' ]; then
      export PROMPT_CTX_ROOT="${USERNAME:-root}"
    elif [ -n "${SSH_CONNECTION-}" ] || [ -n "${SSH_TTY-}" ]; then
      export PROMPT_CTX_REMOTE="${USERNAME}@${HOST%%.*}"
    fi

    # info line (timestamp, stopwatch duration, exit status): exported
    # for starship's env_var modules only when a command actually ran,
    # so fresh shells and bare Enter presses skip the whole line
    zmodload zsh/datetime
    autoload -Uz add-zsh-hook
    typeset -g __prompt_sep='──' __prompt_pipe='│' __prompt_lock=''
    if [ -n "${STARSHIP_CONFIG-}" ]; then
      __prompt_sep='--' __prompt_pipe='|' __prompt_lock='ro'
    fi
    duration-preexec() {
      # a bare `clear` reads as a fresh screen: skip the next info line
      if [[ "${1//[[:space:]]/}" == 'clear' ]]; then
        unset __duration_t0
        return 0
      fi
      __duration_t0="${EPOCHREALTIME}"
    }
    # Ctrl-L clears without running a command; drop the info line and
    # re-render the prompt so it looks like a fresh screen too
    clear-screen-fresh() {
      unset CMD_STAMP CMD_DUR_FMT CMD_STATUS_FMT
      zle clear-screen
      zle reset-prompt
    }
    zle -N clear-screen-fresh
    bindkey '^L' clear-screen-fresh
    duration-precmd() {
      local -i last="${?}"
      local -a pipe_codes=("${pipestatus[@]}")
      if [ -n "${__duration_t0-}" ]; then
        local -F elapsed=$(( EPOCHREALTIME - __duration_t0 ))
        local -i ms=$(( int(elapsed * 1000 + 0.5) ))
        local -i s=$(( ms / 1000 )); ms=$(( ms % 1000 ))
        local -i m=$(( s / 60 ));    s=$(( s % 60 ))
        local -i h=$(( m / 60 ));    m=$(( m % 60 ))
        if (( h )); then
          printf -v CMD_DUR_FMT '%d:%02d:%02d.%03d' "${h}" "${m}" "${s}" "${ms}"
        elif (( m )); then
          printf -v CMD_DUR_FMT '%d:%02d.%03d' "${m}" "${s}" "${ms}"
        else
          printf -v CMD_DUR_FMT '%d.%03d' "${s}" "${ms}"
        fi
        strftime -s CMD_STAMP "%Y/%m/%d ${__prompt_sep} %H:%M:%S" \
          "${EPOCHSECONDS}"
        unset CMD_STATUS_FMT
        if (( last )); then
          if (( ${#pipe_codes} > 1 )); then
            local code joined=''
            for code in "${pipe_codes[@]}"; do
              joined+="${joined:+${__prompt_pipe}}${code}"
            done
            CMD_STATUS_FMT="${joined}"
          else
            CMD_STATUS_FMT="${last}"
          fi
          export CMD_STATUS_FMT
        fi
        export CMD_STAMP CMD_DUR_FMT
        unset __duration_t0
      else
        unset CMD_STAMP CMD_DUR_FMT CMD_STATUS_FMT
      fi
    }
    add-zsh-hook preexec duration-preexec
    add-zsh-hook precmd duration-precmd

    # state-colored git segment (p10k style): parse git status once per
    # prompt and export exactly one GIT_SEG_* variable; starship renders
    # it via env_var modules, one per state color
    typeset -g __git_sym_ahead='' __git_sym_behind='' \
      __git_sym_stash='' __git_sym_conflict='' \
      __git_sym_staged='' __git_sym_unstaged='' \
      __git_sym_untracked=''
    if [ -n "${STARSHIP_CONFIG-}" ]; then
      __git_sym_ahead='>' __git_sym_behind='<' __git_sym_stash='*' \
      __git_sym_conflict='~' __git_sym_staged='+' __git_sym_unstaged='!' \
      __git_sym_untracked='?'
    fi
    git-seg-precmd() {
      unset GIT_SEG_CLEAN GIT_SEG_MODIFIED GIT_SEG_UNTRACKED GIT_SEG_CONFLICT
      local out
      out="$(git --no-optional-locks status --porcelain=v2 --branch \
             --show-stash 2>/dev/null)" ||
      return 0

      local line branch='' oid='' ab=''
      local -i ahead=0 behind=0 stash=0
      local -i staged=0 unstaged=0 untracked=0 conflicted=0
      while IFS= read -r line; do
        case "${line}" in
          ('# branch.head '*) branch="${line#\# branch.head }" ;;
          ('# branch.oid '*)  oid="${line#\# branch.oid }" ;;
          ('# branch.ab '*)
            ab="${line#\# branch.ab }"
            ahead="${${ab%% *}#+}"
            behind="${${ab##* }#-}" ;;
          ('# stash '*) stash="${line#\# stash }" ;;
          ('u '*) (( conflicted++ )) ;;
          ('1 '*|'2 '*)
            [ "${line[3]}" != '.' ] && (( staged++ ))
            [ "${line[4]}" != '.' ] && (( unstaged++ )) ;;
          ('? '*) (( untracked++ )) ;;
        esac
      done <<< "${out}"

      [ "${branch}" = '(detached)' ] && branch="@${oid[1,8]}"
      local seg="${branch}"
      (( behind ))     && seg+=" ${__git_sym_behind}${behind}"
      (( ahead ))      && seg+=" ${__git_sym_ahead}${ahead}"
      (( stash ))      && seg+=" ${__git_sym_stash}${stash}"
      (( conflicted )) && seg+=" ${__git_sym_conflict}${conflicted}"
      (( staged ))     && seg+=" ${__git_sym_staged}${staged}"
      (( unstaged ))   && seg+=" ${__git_sym_unstaged}${unstaged}"
      (( untracked ))  && seg+=" ${__git_sym_untracked}${untracked}"

      if (( conflicted )); then
        export GIT_SEG_CONFLICT="${seg}"
      elif (( staged || unstaged )); then
        export GIT_SEG_MODIFIED="${seg}"
      elif (( untracked )); then
        export GIT_SEG_UNTRACKED="${seg}"
      else
        export GIT_SEG_CLEAN="${seg}"
      fi
    }
    add-zsh-hook precmd git-seg-precmd

    # path segment: fish-style truncation; the git root is bold, venv
    # and node roots take their segment colors (bright-cyan / magenta),
    # a direnv root is underlined when allowed and struck through when
    # blocked, and a lock prefixes the path when cwd isn't writable
    cwd-path-precmd() {
      local esc_base=$'\e[22;24;29;36m' esc_bold=$'\e[1m'
      local esc_ul=$'\e[4m' esc_strike=$'\e[9m'
      local esc_py=$'\e[96m' esc_node=$'\e[35m' esc_bad=$'\e[91m'
      local lock=''
      [ -w "${PWD}" ] || lock="${esc_bad}${__prompt_lock} ${esc_base}"

      # nearest ancestors carrying each marker
      local denv='' pyroot='' nroot='' d="${PWD}"
      while [ -n "${d}" ]; do
        if [ -z "${denv}" ] && [ -e "${d}/.envrc" ]; then
          denv="${d}"
        fi
        if [ -z "${pyroot}" ] &&
           { [ -e "${d}/.venv" ] || [ -e "${d}/venv" ] ||
             [ -e "${d}/.direnv" ]; }; then
          pyroot="${d}"
        fi
        if [ -z "${nroot}" ] && [ -e "${d}/package.json" ]; then
          nroot="${d}"
        fi
        [ "${d}" = '/' ] && break
        d="${d%/*}"; [ -n "${d}" ] || d='/'
      done
      local denv_attr="${esc_strike}"
      if [ -n "${denv}" ] &&
         direnv status 2>/dev/null | grep -Eq 'Found RC allowed (0|true)'
      then
        denv_attr="${esc_ul}"
      fi

      local groot=''
      groot="$(git rev-parse --show-toplevel 2>/dev/null)"

      local abbrev="${(%):-%~}"
      local -a parts=("${(s:/:)abbrev}")
      local -a pwd_parts=("${(s:/:)PWD}")
      local -i n=${#parts} n_pwd=${#pwd_parts}
      local -i i_git=0 i_env=0 i_py=0 i_node=0
      local -a m
      if [ -n "${groot}" ]; then
        m=("${(s:/:)groot}");  i_git=$(( n - (n_pwd - ${#m}) ))
      fi
      if [ -n "${denv}" ]; then
        m=("${(s:/:)denv}");   i_env=$(( n - (n_pwd - ${#m}) ))
      fi
      if [ -n "${pyroot}" ]; then
        m=("${(s:/:)pyroot}"); i_py=$(( n - (n_pwd - ${#m}) ))
      fi
      if [ -n "${nroot}" ]; then
        m=("${(s:/:)nroot}");  i_node=$(( n - (n_pwd - ${#m}) ))
      fi

      local -i i
      local out='' comp col
      for (( i=1; i<=n; i++ )); do
        comp="${parts[i]}"
        if (( i < n && i != i_git && i != i_env &&
              i != i_py && i != i_node )); then
          if (( i >= 2 )); then
            # truncate to the shortest prefix that is unique among sibling
            # directories (p10k truncate_to_unique / real fish behavior), so
            # tab-completing the shown prefix lands on exactly one directory
            local segreal="${PWD}" j=0
            for (( j = i; j < n; j++ )); do segreal="${segreal:h}"; done
            local parentreal="${segreal:h}" segname="${segreal:t}"
            local -a sibs=( ${parentreal}/*(ND/) ); sibs=( ${sibs[@]:t} )
            local -i k=1 matches=0
            # declared once, not inside the loop: re-running `local` on a
            # bare (valueless) name that is already set makes zsh print
            # `name=value` to stdout — which would leak above the prompt
            local pfx='' s=''
            [[ "${segname}" == .* ]] && k=2
            (( k > ${#segname} )) && k=${#segname}
            while (( k < ${#segname} )); do
              pfx="${segname[1,k]}"
              matches=0
              for s in "${sibs[@]}"; do
                [[ "${s}" == "${pfx}"* ]] && (( ++matches ))
              done
              (( matches <= 1 )) && break
              (( ++k ))
            done
            comp="${segname[1,k]}"
          elif [[ "${comp}" == .* ]]; then comp="${comp[1,2]}"
          else comp="${comp[1,1]}"; fi
        fi
        col=''
        (( i_git > 0 && i == i_git )) && col+="${esc_bold}"
        if (( i_py > 0 && i == i_py )); then
          col+="${esc_py}"
        elif (( i_node > 0 && i == i_node )); then
          col+="${esc_node}"
        fi
        (( i_env > 0 && i == i_env )) && col+="${denv_attr}"
        if [ -n "${col}" ]; then
          out+="${col}${comp}${esc_base}"
        else
          out+="${comp}"
        fi
        (( i < n )) && out+='/'
      done
      export CWD_PATH_FMT="${lock}${out}"
    }
    add-zsh-hook precmd cwd-path-precmd

    # k8s segment (workspace-scoped via KUBECONFIG): just the cluster
    # name, underlined when the talos context governs the same cluster
    # and struck through on a mismatch (which also gets a one-shot
    # stderr warning — the two configs should never disagree)
    k8s-seg-precmd() {
      unset K8S_SEG
      [ -n "${KUBECONFIG-}" ] && [ -r "${KUBECONFIG}" ] || return 0
      # read the current context straight from the config file — no kubectl
      # dependency (it may be a broken symlink or off PATH; the file is the
      # source of truth regardless)
      local ctx='' cluster=''
      ctx="$(sed -n 's/^current-context:[[:space:]]*//p' "${KUBECONFIG}" 2>/dev/null | head -1)"
      [ -n "${ctx}" ] || return 0
      cluster="$(awk -v c="${ctx}" '
        $1=="-" && $2=="context:" { cl="" }
        $1=="cluster:"            { cl=$2 }
        $1=="name:" && $2==c      { print cl; exit }
      ' "${KUBECONFIG}" 2>/dev/null)"

      local name
      if [ -n "${cluster}" ]; then
        name="${cluster}"
      elif [[ "${ctx}" == *@* ]]; then
        name="${ctx#*@}"
      else
        name="${ctx}"
      fi

      local attr=''
      if [ -n "${TALOSCONFIG-}" ] && [ -r "${TALOSCONFIG}" ]; then
        local tctx
        tctx="$(sed -n 's/^context: //p' "${TALOSCONFIG}" 2>/dev/null)"
        if [ -n "${tctx}" ]; then
          if [ "${cluster}" = "${tctx}" ] || [ "${ctx}" = "${tctx}" ] ||
             [[ "${ctx}" == *"@${tctx}" ]]; then
            attr=$'\e[4m'
            unset __k8s_warned
          else
            attr=$'\e[9m'
            if [ "${__k8s_warned-}" != "${tctx}:${name}" ]; then
              typeset -g __k8s_warned="${tctx}:${name}"
              printf '\e[91mwarning:\e[0m talos/kube contexts misaligned: talos=%s kube=%s\n' \
                "${tctx}" "${name}" >&2
            fi
          fi
        fi
      else
        unset __k8s_warned
      fi

      if [ -n "${attr}" ]; then
        export K8S_SEG="${attr}${name}"$'\e[24;29m'
      else
        export K8S_SEG="${name}"
      fi
    }
    add-zsh-hook precmd k8s-seg-precmd

    # tmux pane border: mirror the prompt's location segments (cwd, git,
    # k8s) into a pane-local @prompt option. tmux can't compute git/k8s
    # (shell-only) and its border wants #[...] styling rather than ANSI,
    # so a precmd forwards them, translating the cwd/k8s hooks' SGR
    # escapes to tmux style syntax; git/k8s colors mirror starship.toml.
    if [ -n "${TMUX-}" ]; then
      # ANSI SGR (only the codes the prompt hooks emit) -> tmux #[...];
      # result returned in REPLY to avoid a subshell fork each prompt
      __border_ansi2tmux() {
        emulate -L zsh; setopt extendedglob
        local s=$1
        s=${s//$'\e'\[22\;24\;29\;36m/'#[default]#[fg=#{?pane_active,colour6,colour8}]'}
        s=${s//$'\e'\[24\;29m/}
        s=${s//$'\e'\[1m/'#[bold]'}
        s=${s//$'\e'\[4m/'#[underscore]'}
        s=${s//$'\e'\[9m/'#[strikethrough]'}
        s=${s//$'\e'\[96m/'#[fg=#{?pane_active,colour14,colour8}]'}
        s=${s//$'\e'\[35m/'#[fg=#{?pane_active,colour5,colour8}]'}
        s=${s//$'\e'\[91m/'#[fg=#{?pane_active,colour9,colour8}]'}
        s=${s//$'\e'\[0#m/'#[default]'}
        s=${s//$'\e'\[[0-9;]#m/}
        REPLY=$s
      }
      # colored separator between two section colors ($1 left, $2 right);
      # arrows are filled on the active pane, thin on idle (via @ao/@ai)
      __border_sep() {
        REPLY="#[fg=#{?pane_active,$1,colour8}] #{E:@ao}#[fg=#{?pane_active,colour15,colour8}]#{E:@fl}#[fg=#{?pane_active,$2,colour8}]#{E:@ai} #[default]"
      }
      border-seg-precmd() {
        emulate -L zsh; setopt extendedglob
        # out = idle form (colored text); out_active = active form (each
        # section a filled block). Separators are identical in both (arrows
        # colored per neighbor); only the sections differ (text vs block).
        local out='' out_active='' gseg gcol seg segb last
        local pcol=colour15   # #P color (white, active block / idle text)
        # leading separator: #P -> path
        # leading separator (#P -> path): #P's white extends into the space,
        # and the out-triangle stays solid on the active pane
        REPLY="#[bg=#{?pane_active,${pcol},colour8}] #[fg=#{?pane_active,${pcol},colour8} bg=default]#{E:@point-out}#[fg=#{?pane_active,colour15,colour8}]#{E:@fl}#[fg=#{?pane_active,colour6,colour8}]#{E:@ai} #[default]"
        out+="${REPLY}"; out_active+="${REPLY}"
        __border_ansi2tmux "${CWD_PATH_FMT//"#"/"##"}"
        seg="#[fg=#{?pane_active,colour6,colour8}]${REPLY}"
        segb="${seg//"#[fg=colour"/"#[fg=colour0 bg=colour"}"
        out+="${seg}#[default]"; out_active+="${segb}#[default]"
        last=colour6
        # jobs (colour3), when background jobs exist
        local njobs=${(%):-%j}
        if (( ${njobs:-0} )); then
          __border_sep "${last}" colour3; out+="${REPLY}"; out_active+="${REPLY}"
          seg=$'#[fg=#{?pane_active,colour3,colour8}] '"${njobs}"
          segb="${seg//"#[fg=colour"/"#[fg=colour0 bg=colour"}"
          out+="${seg}#[default]"; out_active+="${segb}#[default]"
          last=colour3
        fi
        # python (colour14), when a virtualenv is active
        if [ -n "${VIRTUAL_ENV-}" ]; then
          local pyver='' pydisp=''
          pyver=$(grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' "${VIRTUAL_ENV}/pyvenv.cfg" 2>/dev/null | head -1)
          pydisp="${pyver:-${VIRTUAL_ENV:t}}"
          __border_sep "${last}" colour14; out+="${REPLY}"; out_active+="${REPLY}"
          seg=$'#[fg=#{?pane_active,colour14,colour8}] '"${pydisp//"#"/"##"}"
          segb="${seg//"#[fg=colour"/"#[fg=colour0 bg=colour"}"
          out+="${seg}#[default]"; out_active+="${segb}#[default]"
          last=colour14
        fi
        if [ -n "${K8S_SEG-}" ]; then
          __border_sep "${last}" colour12; out+="${REPLY}"; out_active+="${REPLY}"
          __border_ansi2tmux "${K8S_SEG//"#"/"##"}"
          seg="#[fg=#{?pane_active,colour12,colour8}]󱃾 ${REPLY}"
          segb="${seg//"#[fg=colour"/"#[fg=colour0 bg=colour"}"
          out+="${seg}#[default]"; out_active+="${segb}#[default]"
          last=colour12
        fi
        gseg="${GIT_SEG_CONFLICT-}"; gcol=colour1
        [ -z "${gseg}" ] && { gseg="${GIT_SEG_MODIFIED-}";  gcol=colour11; }
        [ -z "${gseg}" ] && { gseg="${GIT_SEG_UNTRACKED-}"; gcol=colour10; }
        [ -z "${gseg}" ] && { gseg="${GIT_SEG_CLEAN-}";     gcol=colour2;  }
        if [ -n "${gseg}" ]; then
          __border_sep "${last}" "${gcol}"; out+="${REPLY}"; out_active+="${REPLY}"
          seg="#[fg=#{?pane_active,${gcol},colour8}]"$' '"${gseg//"#"/"##"}"
          segb="${seg//"#[fg=colour"/"#[fg=colour0 bg=colour"}"
          out+="${seg}#[default]"; out_active+="${segb}#[default]"
          last="${gcol}"
        fi
        # right edge cap in the last section's color (pid now sits with #P)
        REPLY=" #[fg=#{?pane_active,${last},colour8} bg=default]#{E:@point-thin-out}#[default]"
        out+="${REPLY}"; out_active+="${REPLY}"
        tmux set -p @prompt "${out}"
        tmux set -p @prompt_active "${out_active}"
      }
      add-zsh-hook precmd border-seg-precmd
    fi

    eval "$(starship init zsh)"

    # inside tmux the pane border carries cwd/git/k8s, so collapse the
    # prompt itself to just the chevron (the "tmux" starship profile);
    # the guard keeps the full prompt for any future out-of-tmux use
    if [ -n "${TMUX-}" ]; then
      PROMPT="${PROMPT/ prompt / prompt --profile tmux }"
      RPROMPT=''
    fi
  fi
fi
